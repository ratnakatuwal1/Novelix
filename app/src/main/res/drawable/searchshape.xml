<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Lighter blueish background -->
    <solid android:color="#E6F0FA" />

    <!-- Rounded corners -->
    <corners android:radius="@dimen/_12sdp" />

    <!-- Subtle stroke -->
    <stroke
        android:width="@dimen/_1sdp"
        android:color="#B3D4F5" />

    <!-- Inner padding -->
    <padding
        android:left="8dp"
        android:top="6dp"
        android:right="8dp"
        android:bottom="6dp" />

    <!-- Minimum height -->
    <size android:height="48dp" />
</shape>
